# Porta do servidor Fastify
PORT=3000

# Configurações do PostgreSQL (usadas pelo docker-compose e Prisma)
# ATENÇÃO: os valores abaixo são convenientes para rodar 100% local com o
# docker-compose.yml deste repo (Postgres não exposto fora do host). Em
# produção, troque POSTGRES_PASSWORD por um segredo real gerado — nunca reuse
# este valor de exemplo, mesmo que o Postgres pareça "interno".
POSTGRES_USER=thunderafit
POSTGRES_PASSWORD=CHANGE_ME_IN_PRODUCTION
POSTGRES_DB=thunderafit_db
POSTGRES_PORT=5432

# URL de conexão do Prisma. Use 127.0.0.1, não "localhost" — em algumas
# máquinas Windows a engine do Prisma tenta resolver "localhost" via IPv6
# (::1) e falha em conectar mesmo com o Postgres saudável (o mesmo tipo de
# bug já visto no Invoke-WebRequest do dev.ps1 na Fase 5.5).
DATABASE_URL="postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@127.0.0.1:${POSTGRES_PORT}/${POSTGRES_DB}?schema=public"

# Segredos JWT — gere valores reais com, por exemplo, `openssl rand -base64 48`
# Access token: expiração curta (15min)
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_SECRET_AT_LEAST_32_CHARS

# Refresh token: expiração longa (7d)
JWT_REFRESH_SECRET=CHANGE_ME_TO_ANOTHER_LONG_RANDOM_SECRET_AT_LEAST_32_CHARS

# Origem permitida para CORS (o frontend). Em produção, aponte para o domínio
# real do frontend — nunca use "*" já que os cookies de auth usam credentials.
ALLOWED_ORIGIN=http://localhost:3001

# Ambiente
NODE_ENV=development

# --- Billing / Stripe (Fase 20) ---
# Chaves de TESTE do Stripe até o fundador ativar produção explicitamente.
# NUNCA comite valores reais aqui — mesmo chaves de teste têm valor.
#   STRIPE_SECRET_KEY: chave secreta da API (sk_test_... em teste).
#   STRIPE_WEBHOOK_SECRET: segredo do endpoint de webhook (whsec_...), usado
#     por stripe.webhooks.constructEvent para validar a assinatura. Obtido no
#     Dashboard (Developers > Webhooks) ou impresso pelo `stripe listen`.
#   STRIPE_PRICE_ID_MONTHLY / _ANNUAL: os Price IDs (price_...) dos planos
#     mensal (R$ 9,90) e anual (~R$ 95,04, 20% off) criados no Stripe.
STRIPE_SECRET_KEY=sk_test_CHANGE_ME
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME
STRIPE_PRICE_ID_MONTHLY=price_CHANGE_ME_MONTHLY
STRIPE_PRICE_ID_ANNUAL=price_CHANGE_ME_ANNUAL

# --- Mídia de exercícios (Fase 32) ---
# Nome do bucket GCS onde vídeos/GIFs do catálogo de exercícios são
# armazenados (link do YouTube não precisa disso, vai direto). Em produção
# vem do Terraform (infra/storage.tf). Localmente, sem isso configurado,
# upload de vídeo/GIF falha com erro claro — o catálogo via YouTube continua
# funcionando normalmente.
GCS_BUCKET_NAME=
