// ============================================================
// Prisma Schema — ThunderAfit SaaS Fitness MVP
// Versão: Prisma 5.x (schema único com seções por domínio)
//
// Estrutura futura multi-file (quando migrar para Prisma 6+):
//   prisma/schema/auth.prisma
//   prisma/schema/fitness.prisma    (Fase 3)
//   prisma/schema/billing.prisma    (Fase 2)
//   prisma/schema/progress.prisma   (Fase 4)
// ============================================================

generator client {
  provider      = "prisma-client-js"
  // "native" keeps local dev working (Windows engine for `npm run dev`);
  // "debian-openssl-3.0.x" is the actual runtime target inside the
  // Docker image (node:25-slim, Debian bookworm ships OpenSSL 3.0.x) —
  // pinned explicitly instead of relying on Prisma's build-time OpenSSL
  // auto-detection, which silently guessed wrong and broke at container
  // boot (see Dockerfile comments for the exact failure).
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// --- domain: auth ---
// Módulo de autenticação e gestão de usuários
// Implementado na Fase 1
// ============================================================

model User {
  id               String          @id @default(uuid())
  email            String          @unique
  passwordHash     String
  role             Role
  refreshTokenHash String?
  // Fase 39 — cadastro mínimo de nome: capturado no cadastro a partir de
  // agora (obrigatório pra conta NOVA), mas nullable porque contas já
  // existentes não têm esse dado e não há backfill — todo lugar que exibe
  // nome precisa lidar com null (fallback pro prefixo do e-mail, mesmo
  // padrão já usado na saudação do dashboard).
  name             String?
  planoAssinatura  PlanoAssinatura @default(FREE)
  limiteAlunos     Int             @default(3)
  lastLoginAt      DateTime?
  // Fase 20 (billing Stripe): vínculo do usuário com o Stripe. customerId é
  // setado no checkout.session.completed e usado para mapear eventos de
  // assinatura (updated/deleted) de volta ao usuário. Ambos nullable (usuário
  // FREE nunca teve interação com o Stripe). @unique no customerId garante
  // 1:1 e permite lookup reverso pelo webhook.
  stripeCustomerId     String?     @unique
  stripeSubscriptionId String?
  // Fase 21 (descoberta de profissionais): perfil público mínimo. Opt-in —
  // ninguém aparece na busca até ativar `availableForNewStudents`. location é
  // texto livre (ex: "Palhoça, SC"), sem geolocalização. bio/especialidade
  // texto livre. Só faz sentido para papéis profissionais (PERSONAL/NUTRI).
  availableForNewStudents Boolean @default(false)
  location         String?
  bio              String?
  // Fase 30: foto de perfil pequena (aluno e Personal). Guardada como data
  // URI (ex: "data:image/webp;base64,...") — o redimensionamento/compressão
  // acontece no cliente (canvas, max ~256px) antes do upload, então o
  // arquivo já chega pequeno (poucos KB); sem tabela/bucket separado
  // enquanto o tamanho continuar nessa faixa. Tamanho e formato validados no
  // backend (auth.service.ts), nunca só confiando no cliente.
  avatarUrl        String?
  // i18n: escolha EXPLÍCITA do usuário (tela de Configurações), persistida
  // pra sincronizar entre dispositivos — null significa "nunca escolheu",
  // caso em que o frontend detecta o idioma do sistema (Accept-Language/
  // navigator.language) e usa cookie local, sem gravar aqui até uma escolha
  // real acontecer. Nullable de propósito: não confundir "detectei PT" com
  // "o usuário escolheu PT".
  locale           Locale?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  // Perf (triagem 2026-07-24): apoia connections.repository.searchProfessionals
  // (diretório de descoberta) — filtra por role+disponibilidade antes de
  // qualquer outra coisa, ainda sem índice explícito.
  @@index([role, availableForNewStudents])
  @@map("users")
}

// i18n: 3 idiomas suportados. Maiúsculo por convenção deste schema (mesmo
// padrão de todo outro enum fechado aqui — Role, PlanoAssinatura, etc.); o
// frontend/next-intl usa os códigos minúsculos padrão (pt/en/es) — a
// conversão de caixa acontece na borda da API, não no banco.
enum Locale {
  PT
  EN
  ES
}

enum Role {
  PERSONAL
  ALUNO
  NUTRICIONISTA
  ADMIN
}

// 3 degraus (evolução do antigo FREE/PAGO): Free (3 alunos, hoje), Base (20
// alunos, ganha acesso ao diretório de descoberta — pode ativar
// availableForNewStudents), Plus (ilimitado, destaque/prioridade no
// diretório). Valores em R$ ainda em aberto — o que importa aqui é a
// estrutura de degraus e o filtro correto de quem aparece no diretório.
enum PlanoAssinatura {
  FREE
  BASE
  PLUS
}

// ============================================================
// --- domain: billing --- (Fase 2 — não implementado)
// Gestão de assinaturas e pagamentos
// ============================================================

// ============================================================
// --- domain: fitness ---
// Catálogo de exercícios, prescrição e execução de treinos
// ============================================================

model ClientRelation {
  id                String            @id @default(uuid())
  personalId        String
  alunoId           String
  professionalType  ProfessionalType  @default(PERSONAL)
  createdAt         DateTime          @default(now())

  // Lembrete de pagamento (MASTER_SPEC): o Personal define a próxima data de
  // cobrança; ao logar, o aluno recebe UMA notificação in-app se a data já
  // chegou (sem processamento de pagamento real). paymentReminderDueDate nulo
  // = lembrete desativado. Não precisa de um campo "já disparado" à parte:
  // disparar sempre avança (recorrente) ou limpa (não-recorrente) a própria
  // data, então o mesmo vencimento nunca dispara duas vezes.
  paymentReminderDueDate   DateTime?
  paymentReminderRecurring Boolean   @default(false)

  @@unique([personalId, alunoId])
  // Perf (triagem 2026-07-24): findDueRemindersForAluno filtra só por
  // alunoId — o @@unique acima só serve consultas que também informam
  // personalId (ou o usam sozinho, como prefixo), não alunoId isolado.
  @@index([alunoId])
}

enum ProfessionalType {
  PERSONAL
  NUTRICIONISTA
}

// ============================================================
// --- domain: connections --- (Fase 21)
// Descoberta de profissionais + solicitação de vínculo com aprovação manual.
// O aluno acha um profissional (busca por localização/role) e SOLICITA; o
// vínculo nunca nasce automático — fica PENDENTE até o profissional ACEITAR
// (aí cria o ClientRelation real, respeitando o limite Freemium) ou RECUSAR.
// Mesma filosofia de status do SupportThread (Fase 10).
// ============================================================

model ConnectionRequest {
  id               String                  @id @default(uuid())
  alunoId          String
  professionalId   String
  professionalType ProfessionalType        @default(PERSONAL)
  status           ConnectionRequestStatus @default(PENDENTE)
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  // Um par aluno↔profissional tem no máximo uma solicitação (re-solicitar
  // após recusa reusa a mesma linha, voltando a PENDENTE).
  @@unique([alunoId, professionalId])
  // Perf (triagem 2026-07-24): findRequestsForAluno/findRequestsForProfessional
  // filtram cada um por só uma das duas colunas (+ orderBy createdAt) — o
  // @@unique acima só cobre bem o lado alunoId (prefixo), não professionalId
  // isolado.
  @@index([alunoId, createdAt])
  @@index([professionalId, createdAt])
}

enum ConnectionRequestStatus {
  PENDENTE
  ACEITA
  RECUSADA
}

// ============================================================
// --- domain: fitness ---
// Exercícios, treinos e relação de treino
// ============================================================

model Exercise {
  id              String            @id @default(uuid())
  name            String            @unique
  muscleGroup     String
  equipment       String
  mediaUrl        String?
  // Fase 32: tipo da mídia em mediaUrl. Default YOUTUBE preserva os
  // exercícios já cadastrados (só tinham link do YouTube, sem essa
  // distinção existir ainda).
  mediaType       ExerciseMediaType @default(YOUTUBE)
  description     String
  // Fase 15: nível informativo (não usado em filtro nesta fase). Default
  // INTERMEDIARIO para os 29 exercícios pré-existentes que não declaravam
  // dificuldade — mantém a migration aditiva sem exigir backfill manual.
  difficultyLevel DifficultyLevel   @default(INTERMEDIARIO)
  // Fase 34: marca os ~5 exercícios mais feitos/relevantes de cada grupo
  // muscular (curadoria manual, ver prisma/seed-featured-exercises.ts) —
  // aparecem primeiro dentro do grupo e ganham destaque visual sutil na
  // tela de prescrição. Editável depois pela tela /nimbus/exercicios.
  isFeatured      Boolean           @default(false)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  workoutItems    WorkoutExercise[]
  translations    ExerciseTranslation[]
}

enum DifficultyLevel {
  INICIANTE
  INTERMEDIARIO
  AVANCADO
}

// i18n: traduções de EN/ES sobre o catálogo de exercícios — NUNCA guarda uma
// linha PT (o português já vive direto em `Exercise.name/muscleGroup/
// description`, a fonte da verdade; duplicar aqui violaria o pedido
// explícito de "não duplicar campos na tabela Exercise"). A API pública
// resolve o locale ativo: PT lê `Exercise` direto (sem tocar nesta tabela);
// EN/ES buscam aqui e caem pro valor PT de `Exercise` quando a tradução
// ainda não existe pra aquele exercício — nunca quebra, nunca retorna vazio.
// Cascade delete: se o exercício for apagado, a tradução não fica órfã.
model ExerciseTranslation {
  id          String   @id @default(uuid())
  exerciseId  String
  exercise    Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  locale      Locale
  name        String
  muscleGroup String
  description String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([exerciseId, locale])
}

// Fase 32: YOUTUBE = mediaUrl é um link do YouTube (comportamento antigo,
// sem upload). VIDEO/GIF = mediaUrl é a URL pública de um objeto no bucket
// GCS de mídia de exercícios (infra/storage.tf).
enum ExerciseMediaType {
  YOUTUBE
  VIDEO
  GIF
}

// ============================================================
// --- domain: fitness (Fase 16) — Programas de Treino ---
//
// WorkoutProgram agrupa de 1 a 5 sessões (Workout, letra A-E). Dois papéis
// no mesmo model, distinguidos por `isTemplate`/`alunoId`:
//   - Template puro: isTemplate=true, alunoId=null — pertence ao Personal,
//     reaplicável a qualquer aluno seu.
//   - Instância aplicada: isTemplate=false, alunoId preenchido — a cópia
//     independente que um aluno recebeu.
//
// Decisão CÓPIA vs REFERÊNCIA (documentada): aplicar um template a um aluno
// COPIA a estrutura (programa + sessões + exercícios), não referencia o
// template vivo. Assim, editar o template depois NÃO retroage nos alunos que
// já o receberam — que é o comportamento seguro exigido pelo fundador.
//
// Compatibilidade: cada Workout pré-Fase-16 vira, na migration de dados, um
// WorkoutProgram de 1 sessão (isTemplate=false, alunoId = o do Workout). Por
// isso Workout MANTÉM personalId/alunoId/name/letter — nada é removido, e
// todos os consumidores existentes (progress agrega SetLog por
// workout.alunoId; admin lê via HTTP; frontend lê letter/name/exercises)
// seguem funcionando sem mudança.
// ============================================================

// Fase 26: esquema de rotulagem das sessões do programa, escolhido uma vez na
// criação. LETTER = A-E (5 sessões, ordem alfabética coincide com a ordem de
// treino por acaso). WEEKDAY = Segunda-Domingo (7 sessões, guardado como
// código em Workout.letter — ex: "SEGUNDA" — a ordem de calendário NÃO é a
// ordem alfabética, então todo código que ordena sessões por letter precisa
// consultar o esquema do programa, não usar localeCompare puro.
enum SessionScheme {
  LETTER
  WEEKDAY
}

// Fase 34: distingue um programa PRESCRITO por um Personal (o único tipo que
// existia até aqui) de um programa SELF — template curado pelo admin,
// aplicado pelo próprio aluno, sem Personal nenhum envolvido (base da Fase
// 34.5, "Meu treino pessoal"). Default PERSONAL preserva o significado de
// todo registro pré-existente sem precisar de backfill manual (o Postgres
// já popula o valor default em toda linha antiga na migration ADD COLUMN).
enum WorkoutProgramOrigin {
  PERSONAL
  SELF
}

model WorkoutProgram {
  id            String        @id @default(uuid())
  // Fase 34: nullable — um programa `origin: SELF` não pertence a nenhum
  // Personal (curado pelo admin). Null NÃO significa "sem dono/qualquer
  // dono": significa especificamente "pertence só ao aluno", nunca "visível
  // pro fluxo do Personal". Toda listagem usada pelo Personal (`listByPersonal`)
  // filtra `origin: PERSONAL` explicitamente — nunca lista "tudo", pra nunca
  // vazar um programa SELF pra dentro do fluxo de um Personal por engano.
  personalId    String?
  origin        WorkoutProgramOrigin @default(PERSONAL)
  name          String
  isTemplate    Boolean       @default(false)
  alunoId       String?
  sessionScheme SessionScheme @default(LETTER)
  workouts      Workout[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  // Perf (triagem 2026-07-24): listByPersonal/listByAluno filtram por uma
  // dessas colunas + orderBy createdAt — nenhuma tinha índice antes.
  @@index([personalId, createdAt])
  @@index([alunoId, createdAt])
}

model Workout {
  id              String            @id @default(uuid())
  // programId é NOT NULL após a migration de dados (backfill preenche todo
  // Workout pré-existente). A migration adiciona a coluna como nullable,
  // popula, e só então aplica o NOT NULL — ver migration hand-editada.
  programId       String
  program         WorkoutProgram    @relation(fields: [programId], references: [id])
  // Fase 34: nullable em lockstep com WorkoutProgram.personalId — Workout
  // TEM SEU PRÓPRIO personalId, independente do program (não é herdado via
  // programId), então precisa da mesma mudança pra sessões de um programa
  // SELF não violarem a constraint NOT NULL na criação. Sem `origin` próprio
  // aqui: a segurança já vem de personalId nunca bater com um Personal real
  // quando for null, então toda query `where: { personalId }` já exclui
  // sessões SELF automaticamente, sem precisar de um campo a mais.
  personalId      String?
  // alunoId é nulo quando a sessão pertence a um TEMPLATE (ainda não aplicado
  // a nenhum aluno). Quando o template é aplicado, a cópia tem alunoId
  // preenchido. Consumidores que filtram por alunoId real (progress, posse do
  // aluno) naturalmente ignoram sessões de template — comportamento correto.
  alunoId         String?
  name            String
  letter          String
  // Fase 16: marca a última vez que o aluno concluiu esta sessão. Base para
  // o cálculo de `suggestedNext` (a sessão sugerida é a nunca feita de menor
  // letra; se todas já foram feitas, a de conclusão mais antiga).
  lastCompletedAt DateTime?
  exercises       WorkoutExercise[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  // Perf (triagem 2026-07-24): findAllByAluno/findAllByPersonal filtram por
  // uma dessas colunas + orderBy createdAt; programId é usado em vários
  // lugares (ex: deleteProgram) pra achar todas as sessões de um programa.
  @@index([alunoId, createdAt])
  @@index([personalId, createdAt])
  @@index([programId])
}

model WorkoutExercise {
  id           String   @id @default(uuid())
  workoutId    String
  workout      Workout  @relation(fields: [workoutId], references: [id])
  exerciseId   String
  exercise     Exercise @relation(fields: [exerciseId], references: [id])
  sets         Int
  repsRange    String
  restSeconds  Int
  order        Int
  // Fase 27: observação livre do Personal sobre esta prescrição (ex: "cadência
  // lenta na descida", "trocar se sentir dor"). Sem limite no banco (mesmo
  // padrão dos outros campos de texto livre do schema, ex: Anamnesis) — o
  // limite de 500 caracteres é validado na aplicação (service).
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  setLogs      SetLog[]
}

model SetLog {
  id                 String          @id @default(uuid())
  workoutExerciseId  String
  workoutExercise    WorkoutExercise @relation(fields: [workoutExerciseId], references: [id])
  setNumber          Int
  repsDone           Int
  weightKg           Float
  loggedAt           DateTime        @default(now())

  // Perf (triagem 2026-07-24): toda consulta de SetLog passa por
  // workoutExerciseId (join a partir de WorkoutExercise) combinado com um
  // filtro de intervalo em loggedAt (janela de sessão, histórico, streak) —
  // sem índice antes, cada leitura fazia um scan sequencial da tabela
  // inteira de séries.
  @@index([workoutExerciseId, loggedAt])
}


// ============================================================
// --- domain: progress --- (Fase 8 — implementado)
// Agregação sobre SetLog, sem tabela própria.
// ============================================================

// ============================================================
// --- domain: anamnesis --- (Fase 10)
// Questionário de saúde/histórico do aluno, 1:1 com o aluno.
// ============================================================

model Anamnesis {
  id                  String    @id @default(uuid())
  alunoId             String    @unique
  fullName            String?
  birthDate           DateTime?
  heightCm            Int?
  weightKg            Float?
  goals               String?
  healthConditions    String?
  medications         String?
  activityLevel       String?
  pastExperience      String?
  trainingPreferences String?
  injuries            String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

// ============================================================
// --- domain: support --- (Fase 10)
// Chat simples de dúvidas aluno ↔ Personal (não é tempo real).
// ============================================================

model SupportThread {
  id         String               @id @default(uuid())
  alunoId    String
  personalId String
  subject    String
  status     SupportThreadStatus  @default(ABERTO)
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt
  messages   SupportMessage[]

  // Perf (triagem 2026-07-24): findThreadsForUser filtra por UMA dessas
  // colunas por vez (aluno vê as suas, profissional vê as dele) + orderBy
  // updatedAt.
  @@index([alunoId, updatedAt])
  @@index([personalId, updatedAt])
}

enum SupportThreadStatus {
  ABERTO
  RESPONDIDO
}

model SupportMessage {
  id        String        @id @default(uuid())
  threadId  String
  thread    SupportThread @relation(fields: [threadId], references: [id])
  authorId  String
  text      String
  createdAt DateTime      @default(now())
}

// ============================================================
// --- domain: nutrition --- (Fase 11)
// Catálogo de alimentos e planos de dieta prescritos pelo Nutricionista.
//
// Decisão de granularidade (documentada, Fase 11): `DietFood.quantity` é um
// multiplicador da porção-base do `Food` (ex: `Food.portionDescription` =
// "100g", `quantity = 1.5` => 150g), não um valor absoluto em gramas — evita
// duplicar a lógica de conversão porção↔grama em cada refeição, mesma ideia
// de "backend calcula, frontend só exibe" já usada na Fase 8 (Evolução).
// `DietPlan` representa um dia de plano alimentar (mesmo escopo de "1
// treino = 1 sessão" da Fase 3), com `DietMeal` como as refeições do dia.
// ============================================================

model Food {
  id                 String     @id @default(uuid())
  name               String     @unique
  portionDescription String
  proteinG           Float
  carbsG             Float
  fatG               Float
  kcal               Float
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
  dietFoods          DietFood[]
}

model DietPlan {
  id             String     @id @default(uuid())
  nutricionistaId String
  alunoId        String
  name           String
  // Fase 17 (Item 5): vigência mínima — um único plano ativo por aluno por
  // vez (granularidade suficiente para o MVP; sem datas de início/fim, que
  // seriam superengenharia agora). Criar um novo plano desativa os anteriores
  // do mesmo aluno; o dashboard do aluno mostra o plano ativo em vez do
  // "primeiro da lista". Default true para os planos pré-existentes.
  isActive       Boolean    @default(true)
  meals          DietMeal[]
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
}

model DietMeal {
  id         String     @id @default(uuid())
  dietPlanId String
  dietPlan   DietPlan   @relation(fields: [dietPlanId], references: [id])
  name       String
  time       String
  order      Int
  foods      DietFood[]
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
}

model DietFood {
  id         String   @id @default(uuid())
  dietMealId String
  dietMeal   DietMeal @relation(fields: [dietMealId], references: [id])
  foodId     String
  food       Food     @relation(fields: [foodId], references: [id])
  quantity   Float
  createdAt  DateTime @default(now())
}

// ============================================================
// --- domain: notifications --- (Fase 10)
// Notificação in-app (sino). Sem push real (APNs/FCM) nesta fase
// — decisão documentada no STATUS.md, não implementada aqui.
// ============================================================

model Notification {
  id        String   @id @default(uuid())
  userId    String
  type      String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  // Perf (triagem 2026-07-24): o sino de notificação roda em toda página
  // autenticada — findAllByUser (userId + orderBy createdAt) e countUnread
  // (userId + read=false) são as duas queries mais frequentes do app inteiro.
  @@index([userId, createdAt])
  @@index([userId, read])
}

// ============================================================
// --- domain: admin --- (Fase 14)
// Painel administrativo: histórico de logins e auditoria de acesso a
// dado sensível (anamnese) por admins.
//
// Granularidade decidida (documentada, Fase 14): `User.lastLoginAt` é a
// fonte rápida para "quando foi o último login" (usada na lista paginada
// de usuários, sem precisar agregar). `LoginLog` é um histórico
// append-only apenas de logins BEM-SUCEDIDOS (não de tentativas falhas —
// essas alimentam só o rate limiting, em memória, propositalmente
// efêmero, e nunca viram registro persistido/auditável, já que são ruído
// de segurança, não um evento de produto). Isso cobre o requisito de
// "histórico completo, não só o último" sem duplicar dado.
// ============================================================

model LoginLog {
  id        String   @id @default(uuid())
  userId    String
  ipAddress String?
  createdAt DateTime @default(now())
}

// AdminAccessLog audita especificamente o acesso de um ADMIN a dado de
// saúde (anamnese) — requisito explícito da Fase 14, não um log genérico
// de toda ação administrativa.
model AdminAccessLog {
  id           String   @id @default(uuid())
  adminId      String
  resourceType String
  alunoId      String
  createdAt    DateTime @default(now())
}

// Fase 33: auditoria genérica de ações administrativas de escrita sensíveis
// (hoje só mudança de role de usuário). Tabela separada de AdminAccessLog de
// propósito — aquela é especificamente sobre acesso a anamnese (alunoId
// obrigatório); aqui o alvo não é necessariamente um aluno, então forçar o
// mesmo campo seria enganoso. `details` guarda um resumo legível (ex:
// "PERSONAL -> ADMIN") sem exigir parsing estruturado.
model AdminAuditLog {
  id           String   @id @default(uuid())
  adminId      String
  action       String
  targetUserId String
  details      String
  createdAt    DateTime @default(now())
}
